/*INNER JOIN88*/

SELECT *
FROM employee
INNER JOIN department
ON employee.dept_id=department.dept_id;

SELECT *
FROM employee;

SELECT *
FROM department;

SELECT employee.emp_name,department.dept_name
FROM employee
INNER JOIN department
ON employee.dept_id=department.dept_id;

SELECT employee.emp_name,department.dept_name
FROM employee
INNER JOIN department 
ON employee.dept_id=department.dept_id
WHERE department.dept_name="it";

SELECT employee.emp_name,employee.salary
FROM employee
INNER JOIN department 
ON employee.dept_id=department.dept_id
WHERE employee.salary>60000;

SELECT employee.emp_name,department.dept_name
FROM employee
INNER JOIN department
ON employee.dept_id=department.dept_id;


SELECT department.dept_name,COUNT(employee.dept_id) AS total
FROM employee
INNER JOIN department
ON employee.dept_id=department.dept_id
GROUP BY department.dept_name;

SELECT d.dept_name, COUNT(e.emp_id) AS total
FROM employee e
INNER JOIN department d
ON e.dept_id=d.dept_id
GROUP BY d.dept_name
ORDER BY total DESC
limit 1;
