/*full outer join*/

SELECT *
FROM employee e
LEFT JOIN department d
ON e.dept_id=d.dept_id
UNION
SELECT *
FROM employee e
RIGHT JOIN department d
ON e.dept_id=d.dept_id;

SELECT e.emp_name,d.dept_name
FROM employee e
LEFT JOIN department d
ON e.dept_id=d.dept_id
where d.dept_name IS NULL
UNION
SELECT e.emp_name,d.dept_name
FROM employee e
RIGHT JOIN department d
ON e.dept_id=d.dept_id
WHERE e.emp_name IS NULL;
