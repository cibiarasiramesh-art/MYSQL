FROM employee;

SELECT *
FROM department;

SELECT *
FROM employee
LEFT JOIN department
ON employee.dept_id=department.dept_id;

SELECT d.dept_name,e.emp_name
FROM department d
LEFT JOIN employee e
ON d.dept_id=e.dept_id;

