SELECT d.dept_name,COUNT(d.dept_id) total
FROM department d
LEFT JOIN employee e
ON d.dept_id=e.dept_id
GROUP BY d.dept_name;

SELECT d.dept_id,IFNULL(e.emp_name,'null')
FROM department d
LEFT JOIN employee e
ON d.dept_id=e.dept_id
where e.emp_name IS NULL;
