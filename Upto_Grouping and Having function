/*SELECT*/
SELECT*
FROM employee;

DESCRIBE employee;

SELECT name,salary
FROM employee;

SELECT name,department,city
FROM employee;

SELECT DISTINCT department
FROM employee;

SELECT DISTINCT city
FROM employee;

select*
FROM employee;

/*WHERE*/

SELECT name,salary
 FROM employee
 WHERE salary>60000;

 SELECT name,age
 FROM employee 
 WHERE age>30;

 SELECT name,department
 FROM employee
 WHERE department="it";

 SELECT name,salary
 FROM employee
 WHERE salary>=55000;

 SELECT name,department
 FROM employee
 WHERE department != "it";

 /*NULL*/

 SELECT name,commission
 FROM employee
WHERE commission IS NULL;

SELECT name,commission
FROM employee
WHERE commission IS NOT NULL;

/*LOGICAL OPERATOR*/

/*AND*/
select name,department,salary
FROM employee
where department="it" AND salary>65000;


SELECT name,age,city
FROM employee
WHERE city="chennai" && age>25;

/*or*/

SELECT NAME,department
FROM employee
WHERE department="hr" || department="Finance";

SELECT name,city
FROM employee
where city="CHENNAI" || city="madurai";

/*not*/
SELECT name,department
FROM employee
WHERE department!="SALES";

/*ORDER BY*/
SELECT name,salary
FROM employee
ORDER BY salary ASC;

select name,salary
FROM employee
ORDER BY salary DESC;

select name,age
FROM employee
ORDER BY age;

SELECT name,department,salary
FROM employee
ORDER BY department && salary;

/*limit*/
 SELECT *
 FROM employee
 LIMIT 10;

 select *
 FROM employee
 ORDER BY salary DESC
 LIMIT 3;

 /*OFFSET*/
 SELECT *
 FROM employee
 LIMIT 3
 OFFSET 4;

 SELECT*
 FROM employee
 LIMIT 5
 OFFSET 2;

 /*AGGREGATE FUNCTION*/
 SELECT COUNT(*)
 FROM employee;

 SELECT AVG(salary) AS avgsalary
 FROM employee;

 SELECT MAX(salary) AS maxsalary
 FROM employee;

 SELECT MIN(salary) AS minsalary
 FROM employee;

 SELECT SUM(salary) AS totalsalary
 FROM employee;

 /*group by*/

 SELECT department,COUNT(*) as TOTAL_STRENGTH
 FROM employee
 group BY department;

 SELECT department,AVG(salary)
 FROM employee
 GROUP BY department;

 SELECT department,MAX(salary)
 FROM employee
 GROUP BY department;

 SELECT department,MIN(salary)
 FROM employee
 GROUP BY department,name;

 SELECT department, SUM(salary)
 FROM employee
 GROUP BY department;

 SELECT city,COUNT(*)
 from employee
 GROUP BY city;

 /*having*/
 SELECT department,AVG(salary) AS avgsalary
 FROM employee
 GROUP BY department
 HAVING AVG(salary)>65000;

 SELECT department,COUNT(*) AS total
 FROM employee
 GROUP BY department
 HAVING COUNT(*)>2;

 SELECT city,COUNT(8) as total
 FROM employee
 GROUP BY city
 HAVING COUNT(*)>3;

 SELECT department,max(salary) AS maxsalary
 FROM employee
 GROUP BY department
 HAVING MAX(salary)>70000;

 /*combined queries*/

 SELECT name as highiestsalaryname,salary
 FROM employee
 order by salary DESC
 limit 3;

 SELECT name,salary
 FROM employee
 ORDER BY salary DESC
 limit 1
 OFFSET 1;

 select department,COUNT(*) AS total
 FROM employee
 GROUP BY department
ORDER BY total DESC
limit 1;
